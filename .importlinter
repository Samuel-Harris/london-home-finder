[importlinter]
root_packages =
    lhf
include_external_packages = True

[importlinter:contract:package-layers]
name = Apps and tools are independent above feature libraries above shared libs
type = layers
layers =
    lhf.api | lhf.scraper | lhf.db_app
    lhf.listings
    lhf.db | lhf.repository

[importlinter:contract:listings-public-interface]
name = Listings private modules are only imported inside the listings package
type = protected
protected_modules =
    lhf.listings._listing_row
allowed_importers =
    lhf.listings
    lhf.db_app
